# DCP-AI Environment Configuration
# Copy this file to .env and fill in your values.

# ── Verification Service (port 3000) ──
PORT=3000
DCP_VERSION=2.0
VERIFIER_MODE=hybrid_required          # hybrid_required | hybrid_preferred | classical_only
REQUIRE_SESSION_BINDING=true
REQUIRE_COMPOSITE_BINDING=true
MAX_KEY_AGE_DAYS=365
ALLOW_V1_BUNDLES=true
PQ_CHECKPOINT_INTERVAL=10
ADVISORY_POLL_INTERVAL_MS=86400000

# ── Anchor Service (port 3001) ──
ANCHOR_MODE=batch                      # batch | individual
BATCH_INTERVAL_MS=60000
# ANCHOR_RPC_URL=https://mainnet.base.org
# ANCHOR_PRIVATE_KEY=0x...
# ANCHOR_CONTRACT=0x...

# ── Transparency Log (port 3002) ──
# No additional configuration required beyond PORT and DCP_VERSION.

# ── Revocation Service (port 3003) ──
# No additional configuration required beyond PORT and DCP_VERSION.
