# Copy to .env and fill in your own values. .env is gitignored.
#
# You only need to fill in the chain you intend to deploy to.

# ── Deployment key ──
# Either use a private key directly (DO NOT USE FOR MAINNET):
PRIVATE_KEY=0x

# …or a Foundry keystore account (recommended for real deployments):
# DEPLOYER_ACCOUNT=my-deployer

# ── RPC endpoints ──
# Sepolia (Ethereum testnet)
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_KEY

# Base mainnet (recommended — cheapest gas, ~$0.01 per anchor)
BASE_RPC_URL=https://mainnet.base.org

# Base Sepolia (testnet)
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Optimism / Arbitrum if you prefer
OPTIMISM_RPC_URL=https://mainnet.optimism.io
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc

# ── Block explorer API keys (for automatic source verification) ──
ETHERSCAN_API_KEY=
BASESCAN_API_KEY=
OPTIMISTIC_ETHERSCAN_API_KEY=
ARBISCAN_API_KEY=

# ── Optional: pre-authorise a submitter at deploy time ──
# The owner is always added as submitter automatically. Use this if the
# anchor service will run under a different address than the deployer.
# INITIAL_SUBMITTER=0x0000000000000000000000000000000000000000
