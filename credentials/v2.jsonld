{
  "@context": {
    "@version": 1.1,
    "@protected": true,

    "id": "@id",
    "type": "@type",

    "dcp": "https://dcp-ai.org/credentials/v2#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "sec": "https://w3id.org/security#",
    "schema": "https://schema.org/",

    "DCPAgentPassport": "dcp:DCPAgentPassport",
    "DCPCitizenshipBundle": "dcp:DCPCitizenshipBundle",
    "DCPBundlePresentation": "dcp:DCPBundlePresentation",
    "DCPRight": "dcp:DCPRight",
    "AIAgent": "dcp:AIAgent",

    "name": "schema:name",

    "model": {
      "@id": "dcp:model",
      "@type": "xsd:string"
    },
    "capabilities": {
      "@id": "dcp:capabilities",
      "@container": "@set",
      "@type": "xsd:string"
    },
    "jurisdiction": {
      "@id": "dcp:jurisdiction",
      "@type": "xsd:string"
    },
    "liabilityMode": {
      "@id": "dcp:liabilityMode",
      "@type": "xsd:string"
    },
    "ownerRprHash": {
      "@id": "dcp:ownerRprHash",
      "@type": "xsd:string"
    },
    "status": {
      "@id": "dcp:status",
      "@type": "xsd:string"
    },
    "lifecycleState": {
      "@id": "dcp:lifecycleState",
      "@type": "xsd:string"
    },
    "mandate": {
      "@id": "dcp:mandate",
      "@type": "@id"
    },
    "mandate_id": {
      "@id": "dcp:mandateId",
      "@type": "xsd:string"
    },

    "bundleVersion": {
      "@id": "dcp:bundleVersion",
      "@type": "xsd:string"
    },
    "manifestHash": {
      "@id": "dcp:manifestHash",
      "@type": "xsd:string"
    },
    "securityTier": {
      "@id": "dcp:securityTier",
      "@type": "xsd:string"
    },
    "mandateId": {
      "@id": "dcp:mandateId",
      "@type": "xsd:string"
    },

    "dcpBundle": {
      "@id": "dcp:dcpBundle"
    },
    "created": {
      "@id": "schema:dateCreated",
      "@type": "xsd:dateTime"
    },

    "right": {
      "@id": "dcp:right",
      "@type": "xsd:string"
    },
    "declared_at": {
      "@id": "dcp:declaredAt",
      "@type": "xsd:dateTime"
    }
  }
}
