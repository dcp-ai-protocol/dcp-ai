{
  "name": "@dcp-ai/wasm",
  "version": "2.0.0",
  "description": "WebAssembly module for DCP-AI v2.0 — post-quantum crypto, composite signatures, and full verification in the browser",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./pkg": "./pkg/dcp_ai.js"
  },
  "files": ["dist", "pkg"],
  "scripts": {
    "build:wasm": "cd ../rust && wasm-pack build --target web --out-dir ../wasm/pkg -- --features wasm",
    "build:wasm:node": "cd ../rust && wasm-pack build --target nodejs --out-dir ../wasm/pkg -- --features wasm",
    "build:ts": "tsc",
    "build": "npm run build:wasm && npm run build:ts",
    "test": "echo \"WASM SDK: build-only verification\" && npm run build:ts"
  },
  "keywords": ["dcp", "ai", "wasm", "verification", "post-quantum", "browser", "cryptography"],
  "license": "Apache-2.0",
  "devDependencies": {
    "typescript": "^5.0.0"
  }
}
