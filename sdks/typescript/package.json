{
  "name": "@dcp-ai/sdk",
  "version": "2.1.0",
  "description": "TypeScript SDK for the Digital Citizenship Protocol for AI Agents",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean --define.__DCP_SDK_VERSION__=\\\"2.1.0\\\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1",
    "json-stable-stringify": "^1.1.1",
    "@noble/post-quantum": "^0.5.4"
  },
  "peerDependencies": {
    "@opentelemetry/api": ">=1.7",
    "@opentelemetry/sdk-trace-node": ">=1.17",
    "@opentelemetry/sdk-metrics": ">=1.17",
    "@opentelemetry/exporter-trace-otlp-http": ">=0.44",
    "@opentelemetry/exporter-metrics-otlp-http": ">=0.44",
    "@opentelemetry/resources": ">=1.17",
    "@opentelemetry/semantic-conventions": ">=1.17"
  },
  "peerDependenciesMeta": {
    "@opentelemetry/api": { "optional": true },
    "@opentelemetry/sdk-trace-node": { "optional": true },
    "@opentelemetry/sdk-metrics": { "optional": true },
    "@opentelemetry/exporter-trace-otlp-http": { "optional": true },
    "@opentelemetry/exporter-metrics-otlp-http": { "optional": true },
    "@opentelemetry/resources": { "optional": true },
    "@opentelemetry/semantic-conventions": { "optional": true }
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/json-stable-stringify": "^1.0.36",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^3.2.4",
    "@vitest/coverage-v8": "^3.2.4"
  },
  "overrides": {
    "esbuild": ">=0.25.0",
    "picomatch": ">=4.0.4"
  },
  "keywords": ["dcp", "ai", "agent", "citizenship", "protocol", "verification", "observability", "opentelemetry"],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/dcp-ai-protocol/dcp-ai"
  },
  "homepage": "https://dcp-ai.org",
  "bugs": {
    "url": "https://github.com/dcp-ai-protocol/dcp-ai/issues"
  },
  "author": "DCP-AI Contributors",
  "publishConfig": {
    "access": "public"
  }
}
